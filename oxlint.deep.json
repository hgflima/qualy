{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "jsPlugins": [
    "/Users/henriquelima/dev/personal/qualy/node_modules/quality-metrics/dist/index.cjs"
  ],
  "rules": {
    "quality-metrics/wmc": [
      "error",
      {
        "max": 20
      }
    ],
    "quality-metrics/halstead-volume": [
      "warn",
      {
        "max": 1000
      }
    ],
    "quality-metrics/halstead-effort": [
      "warn",
      {
        "max": 400
      }
    ],
    "quality-metrics/lcom": [
      "warn",
      {
        "max": 2
      }
    ],
    "quality-metrics/cbo": [
      "error",
      {
        "max": 10
      }
    ],
    "quality-metrics/dit": [
      "warn",
      {
        "max": 5
      }
    ]
  }
}
