{
  "name": "@hgflima/qualy",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Deterministic CLI + thin Claude Code harness for the qualy/lint skill (oxlint + oxfmt + quality-metrics).",
  "engines": {
    "node": ">=22.6.0"
  },
  "bin": {
    "qualy": "bin/qualy.mjs"
  },
  "files": [
    "bin/",
    "cli/src/",
    "skills/",
    "commands/",
    "agents/",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspace @qualy/cli",
    "lint": "oxlint --config oxlint.fast.json .",
    "test": "vitest run cli/tests/unit",
    "test:e2e": "vitest run cli/tests/e2e",
    "build": "echo \"[qualy] build: noop — Node 22.6+ executes .ts directly via --experimental-strip-types\" && exit 0",
    "lint:deep": "oxlint --config oxlint.deep.json .",
    "format": "oxfmt --write .",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "quality-metrics": "^0.1.1",
    "ts-morph": "^28.0.0"
  }
}
