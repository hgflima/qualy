{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "jsPlugins": ["quality-metrics"],
  "rules": {
    "quality-metrics/wmc": ["error", { "max": 15 }],
    "quality-metrics/halstead-volume": ["warn", { "max": 800 }],
    "quality-metrics/halstead-effort": ["warn", { "max": 300 }],
    "quality-metrics/lcom": ["warn", { "max": 0 }],
    "quality-metrics/cbo": ["error", { "max": 8 }],
    "quality-metrics/dit": ["warn", { "max": 4 }]
  }
}
