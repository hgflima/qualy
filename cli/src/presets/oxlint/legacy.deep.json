{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "jsPlugins": ["quality-metrics"],
  "rules": {
    "quality-metrics/wmc": ["warn", { "max": 40 }],
    "quality-metrics/halstead": ["warn", { "maxVolume": 2000, "maxEffort": 1000 }],
    "quality-metrics/lcom": ["warn", { "maxLcom": 4 }],
    "quality-metrics/cbo": ["warn", { "max": 20 }],
    "quality-metrics/dit": ["warn", { "max": 6 }]
  }
}
