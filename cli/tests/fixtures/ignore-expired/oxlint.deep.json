{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "jsPlugins": ["quality-metrics"],
  "rules": {
    "quality-metrics/wmc": ["error", { "max": 15 }],
    "quality-metrics/halstead": ["warn", { "maxVolume": 800, "maxEffort": 300 }],
    "quality-metrics/lcom": ["warn", { "maxLcom": 0 }],
    "quality-metrics/cbo": ["error", { "max": 8 }],
    "quality-metrics/dit": ["warn", { "max": 4 }]
  },
  "ignorePatterns": [
    "_qualy:start_",
    "src/legacy/**",
    "_qualy:end_"
  ]
}
