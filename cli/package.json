{
  "name": "@qualy/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic CLI for the qualy/lint skill (oxlint + oxfmt + quality-metrics). Runs directly via Node 22.6+ --experimental-strip-types; no build step.",
  "engines": {
    "node": ">=22.6.0"
  },
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm test --prefix ..",
    "test:e2e": "npm run test:e2e --prefix .."
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "chartjs-chart-treemap": "^3.1.0",
    "esbuild": "^0.24.0",
    "ts-morph": "^24.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
